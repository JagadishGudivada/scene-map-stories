# Sarevista — environment variable reference.
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit
# real secrets. This file documents *names*, not values.

# ---------------------------------------------------------------------------
# Frontend (Vite) — exposed to the client bundle, must be prefixed VITE_
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_GOOGLE_MAPS_API_KEY=
VITE_PEXELS_API_KEY=

# ---------------------------------------------------------------------------
# Supabase (server-side / scripts / edge functions)
# ---------------------------------------------------------------------------
SUPABASE_URL=
# Secret service_role key (starts with "eyJ..."). Required for scripts that
# bypass RLS, e.g. scripts/data-quality-scan.mjs and scripts/agent-*-enrichment.py.
# NEVER use a publishable/anon key here for write operations.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# AI providers
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_API_KEY_XAI=
TMDB_API_KEY=

# GCP / Vertex AI (grounded generation, used by *-enrichment-vertex functions)
GCP_PROJECT_ID=
GCP_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ---------------------------------------------------------------------------
# Accuracy pipeline env (Location Data Accuracy Overhaul — see
# supabase/functions/_shared/geocode.ts and _shared/confidence.ts)
# ---------------------------------------------------------------------------
# Google Geocoding API key used as authoritative ground-truth for coordinate
# cross-checking (supabase/functions/_shared/geocode.ts:geocodePlace). Required
# for coordinate verification / geo_verified to ever be set true; without it,
# geocodePlace() logs a warning and returns null (coords stay unverified).
GEOCODING_API_KEY=

# Max allowed distance (km) between AI-guessed and geocoded coordinates for a
# spot/POI before the geocoder result replaces the AI coordinate. Skipped for
# city-level `locations`. Default: 2 (see geocode.ts:crossCheckCoordinates).
GEOCODE_MAX_DISTANCE_KM=2

# Number of self-consistency runs (grounded generation at temperature 0.2) the
# enrichment functions perform per title/spot before merging agreement into
# the confidence score. Default: 2.
ENRICHMENT_CONSISTENCY_RUNS=2

# Distance threshold (km) used when merging locations across self-consistency
# runs into the same candidate (same normalized label + within this radius
# counted as "recurring"). Default: 25.
ENRICHMENT_MERGE_KM=25

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
EMAIL_KEY=
EMAIL_SERVER_NAME=
EMAIL_USER_NAME=
EMAIL_FROM=
EMAIL_TO=

# ---------------------------------------------------------------------------
# Misc / legacy
# ---------------------------------------------------------------------------
DATABASE_URL=
SUPABASE_URL_OLD=
